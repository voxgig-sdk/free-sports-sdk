# BasicEventFlow

main: kit: flow: BasicEventFlow:
{
  entity: "event",
  kind: "basic",
  name: "BasicEventFlow",
  step: [
    {
      match: {
        api_key: "api_key01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "event_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicEventFlow"
}