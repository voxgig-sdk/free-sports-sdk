{
  "openapi": "3.0.3",
  "info": {
    "title": "Free Sports API",
    "description": "Provides free JSON sports API for accessing basic sports data, including information on teams, players, events, and more. Offers test API keys, API limits, and upgrade options for premium features.",
    "version": "1.0.0",
    "contact": {
      "email": "info@thesportsdb.com"
    },
    "termsOfService": "https://www.thesportsdb.com/terms"
  },
  "servers": [
    {
      "url": "https://www.thesportsdb.com/api/v1/json",
      "description": "Production server (API v1)"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/{apiKey}/searchteams.php": {
      "get": {
        "summary": "Search for teams",
        "description": "Search for teams by team name",
        "operationId": "searchTeams",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "t",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Team name to search for"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with team data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "teams": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Team"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        }
      }
    },
    "/{apiKey}/searchplayers.php": {
      "get": {
        "summary": "Search for players",
        "description": "Search for players by player name",
        "operationId": "searchPlayers",
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "p",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Player name to search for"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with player data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "player": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Player"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        }
      }
    },
    "/{apiKey}/searchevents.php": {
      "get": {
        "summary": "Search for events",
        "description": "Search for sporting events by event name",
        "operationId": "searchEvents",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "e",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Event name to search for"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with event data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Event"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        }
      }
    },
    "/{apiKey}/all_leagues.php": {
      "get": {
        "summary": "Get all leagues",
        "description": "Retrieve a list of all available sports leagues",
        "operationId": "getAllLeagues",
        "tags": [
          "Leagues"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with league data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "leagues": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/League"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        }
      }
    },
    "/{apiKey}/lookupleague.php": {
      "get": {
        "summary": "Lookup league details",
        "description": "Get detailed information about a specific league by league ID",
        "operationId": "lookupLeague",
        "tags": [
          "Leagues"
        ],
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "League ID to lookup"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with league details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "leagues": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LeagueDetail"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "404": {
            "description": "League not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
